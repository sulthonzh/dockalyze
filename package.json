{
  "name": "dockalyze",
  "version": "1.0.0",
  "description": "Zero-dependency Docker image analyzer and security scanner",
  "main": "dist/index.js",
  "bin": {
    "dockalyze": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "node --test test/*.mjs",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test:standalone": "node --test test/test.mjs"
  },
  "keywords": [
    "docker",
    "security",
    "analysis",
    "scanner",
    "vulnerability",
    "image",
    "container",
    "cli"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "chalk": "^5.0.0",
    "commander": "^15.0.0",
    "eslint": "^10.0.0",
    "jest": "^30.0.0",
    "ora": "^9.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^6.0.0"
  }
}